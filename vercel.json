{
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/api/openai/:path*",
      "destination": "https://api.openai.com/:path*"
    },
    {
      "source": "/api/xai/:path*",
      "destination": "https://api.x.ai/:path*"
    },
    {
      "source": "/api/groq/:path*",
      "destination": "https://api.groq.com/:path*"
    },
    {
      "source": "/api/huggingface/:path*",
      "destination": "https://api-inference.huggingface.co/:path*"
    },
    {
      "source": "/api/openrouter/:path*",
      "destination": "https://openrouter.ai/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
